---
interface Props {
  variant?: "stars";
  space?: "default" | "wide" | "tall";
}
const { variant = "stars", space = "default" } = Astro.props;
---
<div
  class:list={["rule", `rule-${variant}`, space !== "default" && `rule-${space}`]}
  role="separator"
  aria-hidden="true"
>*   *   *</div>

<style>
  .rule {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--c-mute);
    text-align: center;
    margin: var(--s-4) auto;
    letter-spacing: 1em;
    user-select: none;
  }
  .rule-wide { margin: var(--s-5) auto; }
  .rule-tall { margin: var(--s-5) auto var(--s-3); }
</style>

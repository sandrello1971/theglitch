---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  pageType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Effetto Glitch — posizione critica sul racconto dominante dell'AI in Italia. Diario di osservazioni per chi non vuole farsi raccontare miracoli.",
  image = "/og/glitch-effetto-umano.png",
  imageWidth = 1200,
  imageHeight = 630,
  pageType = "website",
  publishedTime,
  modifiedTime,
  author = "Stefano Andrello",
  section,
  robots = "index, follow",
  jsonLd,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://www.effettoglitch.it");
const canonical = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL(image, siteOrigin);

const siteJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": new URL("/#website", siteOrigin).href,
    name: "Effetto Glitch",
    alternateName: "Glitch",
    url: siteOrigin.href,
    description:
      "Posizione critica sul racconto dominante dell'intelligenza artificiale italiana. Diario di osservazioni per chi non vuole farsi raccontare miracoli.",
    inLanguage: "it-IT",
    publisher: { "@id": new URL("/#person", siteOrigin).href },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": new URL("/#person", siteOrigin).href,
    name: "Stefano Andrello",
    alternateName: "Glitch",
    jobTitle: "AI Strategist",
    url: siteOrigin.href,
    sameAs: ["https://stefanoandrello.me"],
    knowsAbout: [
      "Intelligenza artificiale",
      "AI literacy",
      "EU AI Act",
      "Piccole e medie imprese",
      "Umanesimo digitale",
    ],
  },
];

const allJsonLd = jsonLd
  ? [...siteJsonLd, ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])]
  : siteJsonLd;

import "../styles/base.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark" />
    <meta name="google-site-verification" content="5fMj9DFpo5MtPNe30r493OykSZ5kl9s_X4CN___F7EQ" />
    <link rel="canonical" href={canonical.href} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <link rel="alternate" type="application/rss+xml" title="Effetto Glitch — Segnali" href="/rss.xml" />

    <meta property="og:type" content={pageType} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content="Effetto Glitch" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.href} />
    {imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    <meta property="og:url" content={canonical.href} />

    {pageType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {pageType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {pageType === "article" && author && (
      <meta property="article:author" content={author} />
    )}
    {pageType === "article" && section && (
      <meta property="article:section" content={section} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:url" content={canonical.href} />

    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />
  </head>
  <body>
    <SiteHeader />
    <main><slot /></main>
    <SiteFooter />
  </body>
</html>

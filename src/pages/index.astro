---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Content, frontmatter } from "../content/manifesto.md";
---
<BaseLayout
  title="Glitch — Il glitch è umano."
  description={frontmatter.summary}
>
  <article class="manifesto container">
    <img
      src="/glitch-logo.png"
      alt="Effetto Glitch"
      class="logo"
      width="160"
      height="131"
    />
    <p class="kicker">Manifesto — Aprile 2026</p>
    <h1 class="title" data-text="Il glitch è umano.">Il glitch è umano.</h1>
    <div class="prose">
      <Content />
    </div>
    <p class="signature">— Glitch</p>

    <section class="bio">
      <p class="kicker">Chi</p>
      <p>Glitch è scritto da Stefano Andrello, AI Strategist e fondatore di Noscite. Ha pubblicato tre libri sull'intelligenza artificiale e l'umanesimo digitale:</p>
      <ul class="book-list">
        <li>«Restare umani — Guida all'intelligenza artificiale per chi non vuole smettere di pensare»</li>
        <li>«Il Futuro non è scritto — Memorie di un'Intelligenza Artificiale»</li>
        <li>«L'Intelligenza Artificiale in Pratica — Guida critica per educatori e professionisti»</li>
      </ul>
      <p class="contact">Il sito personale è <a href="https://stefanoandrello.me" target="_blank" rel="noopener">stefanoandrello.me</a>.</p>
    </section>
  </article>
</BaseLayout>

<style>
  .manifesto {
    padding-block: var(--s-3) var(--s-3);
  }

  .logo {
    display: block;
    width: auto;
    max-width: 160px;
    height: auto;
    margin: 0 0 var(--s-3) 0;
  }

  .kicker {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-wide);
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }

  /* Title — RGB split moment */
  .title {
    position: relative;
    isolation: isolate;
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(3rem, 12vw, var(--t-display));
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--c-fg);
    font-optical-sizing: auto;
    text-align: left;
    margin-bottom: var(--s-4);
  }
  .title::before,
  .title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    font: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    white-space: pre;
    opacity: 0;
    mix-blend-mode: screen;
  }
  .title::before {
    color: var(--c-signal);
    animation: rgb-shift-red 800ms steps(12) forwards;
  }
  .title::after {
    color: var(--c-glitch-cyan);
    animation: rgb-shift-cyan 800ms steps(12) forwards;
  }
  @keyframes rgb-shift-red {
    from { transform: translate(-12px, 0); opacity: 1; }
    to   { transform: translate(0, 0);     opacity: 0; }
  }
  @keyframes rgb-shift-cyan {
    from { transform: translate(12px, 0); opacity: 1; }
    to   { transform: translate(0, 0);    opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .title::before, .title::after { animation: none; }
  }


  /* Reading column — mono inherited from body */
  .prose {
    max-width: var(--measure);
    line-height: 1.55;
    text-align: left;
    margin-bottom: var(--s-5);
  }

  .prose :global(p) {
    margin: 0 0 var(--s-2) 0;
  }
  .prose :global(p:last-child) {
    margin-bottom: 0;
  }
  .prose :global(strong) {
    font-weight: 600;
    color: var(--c-fg);
  }
  .prose :global(em) {
    font-style: italic;
  }

  /* Section dividers from markdown --- (mono pattern via ::before) */
  .prose :global(hr) {
    border: 0;
    height: 0;
    margin: 0;
    overflow: visible;
    text-align: center;
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--c-mute);
  }
  .prose :global(hr::before) {
    content: "*   *   *";
    display: block;
    margin-block: var(--s-4);
    letter-spacing: 1em;
  }

  /* Lead paragraph — same mono, slight size bump */
  .prose > :global(p:first-of-type) {
    font-size: var(--t-base);
    line-height: 1.5;
    color: var(--c-fg);
  }

  /* Numbered errors — serif marginalia */
  .prose :global(ol) {
    list-style: none;
    padding: 0;
    margin: var(--s-4) 0;
    counter-reset: error-counter;
  }
  .prose :global(ol > li) {
    position: relative;
    counter-increment: error-counter;
    margin-bottom: var(--s-4);
  }
  .prose :global(ol > li:last-child) {
    margin-bottom: 0;
  }
  .prose :global(ol > li::before) {
    content: counter(error-counter, decimal-leading-zero);
    position: absolute;
    left: -4rem;
    top: -0.1em;
    font-family: var(--f-display);
    font-weight: 600;
    font-size: var(--t-xl);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-signal);
    font-optical-sizing: auto;
  }

  /* Pull quotes — mono uppercase signal */
  .prose :global(blockquote) {
    font-family: var(--f-mono);
    font-style: normal;
    font-size: var(--t-md);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-signal);
    border-left: 2px solid var(--c-signal);
    padding-left: var(--s-2);
    margin: var(--s-4) 0 var(--s-4) calc(-1 * var(--s-3));
  }
  .prose :global(blockquote p) {
    margin: 0;
  }

  /* Signature */
  .signature {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-align: right;
    color: var(--c-fg);
  }

  /* Bio section */
  .bio {
    max-width: var(--measure);
    margin-top: var(--s-5);
  }
  .bio p {
    margin: 0 0 var(--s-3) 0;
  }
  .bio .book-list {
    list-style: none;
    padding: 0;
    margin: var(--s-3) 0;
  }
  .bio .book-list li {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--t-base);
    color: var(--c-fg);
    margin-block: 0.4rem;
    font-optical-sizing: auto;
  }
  .bio .contact {
    margin-top: var(--s-3);
    margin-bottom: 0;
  }
  .bio .contact a {
    color: var(--c-signal);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (max-width: 1023px) {
    .prose :global(ol > li::before) {
      position: static;
      display: block;
      font-size: var(--t-lg);
      margin-bottom: var(--s-1);
    }
    .prose :global(blockquote) {
      margin-left: 0;
    }
  }
</style>

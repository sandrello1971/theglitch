---
import BaseLayout from "../layouts/BaseLayout.astro";
import Rule from "../components/Rule.astro";

const mailSubject = "Un glitch";
const mailBody = `Dove è successo (azienda, scuola, PA, altro):


Cosa non tornava:


La domanda che nessuno aveva fatto:


—
(Se vuoi restare anonimo, dimmelo: non userò il tuo nome.)`;

const mailHref = `mailto:rumore@effettoglitch.it?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;
---
<BaseLayout
  title="Partecipa — Effetto Glitch"
  description="Hai visto un glitch nel racconto dell'AI? Raccontacelo. Effetto Glitch raccoglie le storie di chi, dentro il lavoro reale, ha fatto la domanda giusta quando tutti applaudivano."
>
  <article class="partecipa container">
    <p class="kicker">Partecipa</p>
    <h1 class="title">Hai visto un glitch?</h1>

    <div class="prose">
      <p class="lead">
        Un'AI promessa come magia e consegnata come confusione. Una domanda che nessuno ha fatto prima di adottare un sistema. Un software che non parla la lingua di chi deve usarlo. Quei momenti in cui qualcosa, nel racconto dell'intelligenza artificiale, non torna — quelli sono glitch. E i glitch sono umani.
      </p>

      <p>
        Effetto Glitch raccoglie queste storie. Non per fare l'elenco di ciò che non funziona, ma per dare voce a chi, dentro il lavoro reale, ha fatto la domanda giusta quando tutti applaudivano.
      </p>

      <p>
        Se ti è capitato — in azienda, a scuola, nella pubblica amministrazione, da genitore — raccontacelo. Bastano poche righe:
      </p>

      <ul class="prompts">
        <li>Dove è successo (azienda, scuola, PA, altro)</li>
        <li>Cosa non tornava</li>
        <li>La domanda che nessuno aveva fatto</li>
      </ul>
    </div>

    <section class="cta-block">
      <p class="cta-label">Scrivi a</p>
      <a href={mailHref} class="cta-mail">rumore@effettoglitch.it</a>
      <p class="cta-hint">Cliccando si apre il tuo client di posta con i tre punti già pronti da riempire.</p>
    </section>

    <Rule variant="stars" />

    <blockquote class="closer">
      Se anche tu fai domande scomode quando tutti applaudono, sei già parte del rumore.
    </blockquote>
  </article>
</BaseLayout>

<style>
  .partecipa {
    --measure: 70ch;
    padding-block: var(--s-3) var(--s-3);
  }

  .kicker {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.15em;
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }

  .title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-xxl);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-fg);
    font-optical-sizing: auto;
    text-align: left;
    margin-bottom: var(--s-4);
  }

  .prose {
    max-width: var(--measure);
    line-height: 1.55;
  }
  .prose p {
    margin: 0 0 var(--s-2) 0;
    color: var(--c-fg);
  }
  .prose .lead {
    font-size: var(--t-base);
    line-height: 1.5;
    color: var(--c-fg);
  }

  .prompts {
    list-style: none;
    padding: 0;
    margin: var(--s-3) 0;
    border-left: 2px solid var(--c-rule);
  }
  .prompts li {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--c-fg);
    padding: 0.3rem 0 0.3rem var(--s-2);
    line-height: 1.45;
  }

  .cta-block {
    max-width: var(--measure);
    margin: var(--s-4) 0 0 0;
    border: 1px solid var(--c-rule);
    padding: var(--s-3);
  }
  .cta-label {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-mute);
    margin: 0 0 var(--s-2) 0;
  }
  .cta-mail {
    display: inline-block;
    font-family: var(--f-mono);
    font-size: var(--t-md);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--c-signal);
    text-decoration: underline;
    text-underline-offset: 0.25em;
    margin-bottom: var(--s-2);
  }
  .cta-mail:hover,
  .cta-mail:focus-visible {
    color: var(--c-fg);
    outline: none;
  }
  .cta-hint {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--c-mute);
    margin: var(--s-1) 0 0 0;
  }

  /* Blockquote chiusura — stesso pattern del manifesto e dei segnali */
  .closer {
    max-width: var(--measure);
    font-family: var(--f-mono);
    font-style: normal;
    font-size: var(--t-md);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-signal);
    border-left: 2px solid var(--c-signal);
    padding-left: var(--s-2);
    margin: var(--s-4) 0 0 calc(-1 * var(--s-3));
  }

  @media (max-width: 720px) {
    .closer {
      margin-left: 0;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Rule from "../../components/Rule.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const all = await getCollection("segnali", ({ data }) => !data.draft);
  const sorted = all.sort((a, b) => a.data.numero - b.data.numero);
  return sorted.map((entry, idx) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: sorted[idx - 1] ?? null,
      next: sorted[idx + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat("it-IT", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const numero = String(entry.data.numero).padStart(3, "0");
const dataFmt = dateFormatter.format(entry.data.data);

const wordCount = (entry.body ?? "").split(/\s+/).filter(Boolean).length;
let tempoLettura = entry.data.tempoLettura;
if (!tempoLettura) {
  const minutes = Math.max(1, Math.ceil(wordCount / 200));
  tempoLettura = `${minutes} min`;
}

const eyebrow = `Segnale #${numero} · ${dataFmt} · ${tempoLettura}`;

const siteOrigin = Astro.site ?? new URL("https://www.effettoglitch.it");
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const isoDate = entry.data.data.toISOString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: entry.data.titolo,
  alternativeHeadline: `Segnale #${numero}`,
  description: entry.data.sommario,
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  datePublished: isoDate,
  dateModified: isoDate,
  inLanguage: "it-IT",
  articleSection: "Segnali",
  wordCount,
  image: new URL("/og/glitch-effetto-umano.png", siteOrigin).href,
  author: { "@id": new URL("/#person", siteOrigin).href },
  publisher: { "@id": new URL("/#person", siteOrigin).href },
  isPartOf: { "@id": new URL("/#website", siteOrigin).href },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Manifesto",
      item: siteOrigin.href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Segnali",
      item: new URL("/segnali/", siteOrigin).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.titolo,
      item: canonicalUrl,
    },
  ],
};
---
<BaseLayout
  title={`Segnale #${numero} — ${entry.data.titolo} — Glitch`}
  description={entry.data.sommario}
  pageType="article"
  publishedTime={isoDate}
  modifiedTime={isoDate}
  section="Segnali"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="segnale container">
    <p class="kicker">{eyebrow}</p>
    <h1 class="title">{entry.data.titolo}</h1>

    <Rule variant="stars" />

    <div class="prose">
      <Content />
    </div>

    <Rule variant="stars" />

    <p class="signature">— Glitch</p>

    <nav class="paging" aria-label="Navigazione segnali">
      <p class="all"><a href="/segnali/">tutti i segnali</a></p>
      <div class="prev-next">
        {prev && <a href={`/segnali/${prev.id}/`} class="prev">← Segnale precedente</a>}
        {next && <a href={`/segnali/${next.id}/`} class="next">Segnale successivo →</a>}
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  .segnale {
    padding-block: var(--s-3) var(--s-3);
    --measure: 80ch;
  }
  .kicker {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.15em;
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }
  .title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-xxl);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-fg);
    font-optical-sizing: auto;
    text-align: left;
    margin-bottom: 0;
  }
  .prose {
    max-width: var(--measure);
    line-height: 1.55;
    text-align: left;
  }
  .prose :global(p) { margin: 0 0 var(--s-2) 0; }
  .prose :global(p:last-child) { margin-bottom: 0; }
  .prose :global(strong) { font-weight: 600; color: var(--c-fg); }
  .prose :global(em) { font-style: italic; }

  /* Pull quote — uguale al manifesto */
  .prose :global(blockquote) {
    font-family: var(--f-mono);
    font-style: normal;
    font-size: var(--t-md);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-signal);
    border-left: 2px solid var(--c-signal);
    padding-left: var(--s-2);
    margin: var(--s-4) 0 var(--s-4) calc(-1 * var(--s-3));
  }
  .prose :global(blockquote p) { margin: 0; }

  /* hr da --- — pattern mono coerente col manifesto */
  .prose :global(hr) {
    border: 0;
    height: 0;
    margin: 0;
    overflow: visible;
    text-align: center;
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--c-mute);
  }
  .prose :global(hr::before) {
    content: "*   *   *";
    display: block;
    margin-block: var(--s-4);
    letter-spacing: 1em;
  }

  .signature {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-align: right;
    color: var(--c-fg);
    margin: 0;
  }

  .paging {
    margin-top: var(--s-5);
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--c-mute);
  }
  .paging .all { margin: 0 0 var(--s-2) 0; }
  .paging .all a {
    color: var(--c-mute);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .paging .all a:hover { color: var(--c-signal); }

  .prev-next {
    display: flex;
    gap: var(--s-2);
  }
  .prev-next a {
    color: var(--c-mute);
    text-decoration: none;
  }
  .prev-next a:hover { color: var(--c-signal); }
  .prev-next .next { margin-left: auto; }

  @media (max-width: 720px) {
    .prev-next { flex-direction: column; }
    .prev-next .next { margin-left: 0; }
  }
</style>

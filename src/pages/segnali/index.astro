---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Segnali — Glitch"
  description="In arrivo."
>
  <article class="segnali container">
    <p class="kicker">Segnali</p>
    <h1 class="title">Segnali.</h1>
    <p class="status">In arrivo. Il primo segnale uscirà col lancio del sito.</p>
  </article>
</BaseLayout>

<style>
  .segnali {
    padding-block: var(--s-3) var(--s-3);
  }

  .kicker {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.15em;
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }

  .title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: var(--t-xxl);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-fg);
    font-optical-sizing: auto;
    text-align: left;
    margin-bottom: var(--s-4);
  }

  .status {
    font-family: var(--f-mono);
    font-size: var(--t-base);
    color: var(--c-mute);
    margin: 0;
  }
</style>
